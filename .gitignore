# ─────────────────────────────────────────────────────────────────────────────
# activity-platform — monorepo .gitignore
# Covers: backend (Node/Express/TS), frontend (Angular), packages/shared
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
out-tsc/
bazel-out/
tmp/
build/

# ── Environment & secrets — NEVER commit these ────────────────────────────────
.env
.env.*
!.env.example
config.env
*.pem
*.key

# ── Prisma generated client ───────────────────────────────────────────────────
backend/src/generated/

# ── Angular cache ─────────────────────────────────────────────────────────────
.angular/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
libpeerconnection.log
testem.log

# ── Test & coverage ───────────────────────────────────────────────────────────
coverage/
__screenshots__/
*.lcov

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# VS Code — keep shared settings, ignore personal/machine-specific files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Firebase ──────────────────────────────────────────────────────────────────
.firebase/
*-debug.log
.runtimeconfig.json

# ── Misc ──────────────────────────────────────────────────────────────────────
.sass-cache/
connect.lock
typings/

